# Runtime mode selection for deployment topology.
SPOT_TRAIN_RUNTIME_MODE=off_robot

# Model serving for Strands.
SPOT_TRAIN_MODEL_PROVIDER=bedrock
SPOT_TRAIN_BEDROCK_REGION=us-west-2
SPOT_TRAIN_BEDROCK_MODEL_ID=<bedrock-model-id>

# Planned local-first storage locations.
SPOT_TRAIN_DB_PATH=data/world.sqlite
SPOT_TRAIN_ARTIFACT_DIR=data/artifacts

# Reserved for future adapter wiring.
SPOT_TRAIN_PROFILE_DIR=profiles
